# App Settings
APP_NAME="Metaphor Context Engine"
DEBUG=True

# Security
METAPHOR_API_KEY="metaphor_dev_secret_key_123"

# Database (Postgres inside Docker)
DATABASE_URL="postgresql+asyncpg://postgres:postgrespassword@localhost:5432/metaphor"

# LLM Providers
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Integration Developer Tokens
NOTION_INTEGRATION_TOKEN="your-notion-integration-token"
GITHUB_PERSONAL_ACCESS_TOKEN="your-github-personal-access-token"

# Google Service Account Credentials File Path
GOOGLE_SERVICE_ACCOUNT_JSON_PATH="credentials/google-service-account.json"
